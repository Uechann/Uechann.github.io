# Notion → Hugo 동기화용 환경변수
# 이 파일을 복사해 .env 로 만들고 값을 채우세요 (cp .env.example .env)
# .env 는 .gitignore 에 의해 커밋되지 않습니다.

# Notion 통합(Integration) 시크릿 토큰 (https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 글 목록 데이터베이스 ID (DB URL의 32자리 hex 부분)
NOTION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
